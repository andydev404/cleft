---
import Layout from '../layouts/Layout.astro';
import { PaletteDemo } from '../components/PaletteDemo';

const DOWNLOAD_URL = 'https://github.com/andydev404/cleft/releases/latest';
const REPO_URL = 'https://github.com/andydev404/cleft';
---

<Layout
  title="Cleft — the clipboard manager that remembers everything"
  description="Your clipboard holds one item. Cleft keeps everything you copy — searchable, organized, and stored only on your device. Free and open source for macOS and Windows."
>
  <div class="scroll-progress" aria-hidden="true"></div>
  <nav class="nav">
    <div class="wrap nav-inner">
      <a class="brand" href="/">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <defs>
            <linearGradient id="brand-g" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0" stop-color="#ffa02b" />
              <stop offset="1" stop-color="#ff5f2e" />
            </linearGradient>
          </defs>
          <rect x="3" y="3" width="18" height="18" rx="5" fill="url(#brand-g)" />
          <path d="M12 3v6l2.5-2L17 9V3" fill="#08090c" />
        </svg>
        Cleft
      </a>
      <a class="nav-link optional" href="#features">Features</a>
      <a class="nav-link optional" href="#privacy">Privacy</a>
      <a class="nav-link" href={REPO_URL} rel="noopener">GitHub</a>
      <a class="btn btn-primary btn-small" href={DOWNLOAD_URL} rel="noopener">Download</a>
    </div>
  </nav>

  <header class="hero">
    <div class="glyph-field" aria-hidden="true">
      <i style="top:14%;left:9%;font-size:22px;opacity:.10">⌘</i>
      <i style="top:32%;left:16%;font-size:13px;opacity:.07;filter:blur(1px)">{'{ }'}</i>
      <i style="top:58%;left:7%;font-size:17px;opacity:.09">#</i>
      <i style="top:76%;left:14%;font-size:14px;opacity:.06;filter:blur(1.5px)">→</i>
      <i style="top:22%;left:26%;font-size:15px;opacity:.06;filter:blur(1px)">⇧</i>
      <i style="top:11%;right:11%;font-size:19px;opacity:.10">V</i>
      <i style="top:30%;right:20%;font-size:14px;opacity:.07;filter:blur(1px)">//</i>
      <i style="top:52%;right:8%;font-size:22px;opacity:.09">⌘</i>
      <i style="top:70%;right:16%;font-size:13px;opacity:.06;filter:blur(1.5px)">:=</i>
      <i style="top:44%;right:28%;font-size:15px;opacity:.05;filter:blur(2px)">⌫</i>
      <i style="top:84%;left:31%;font-size:16px;opacity:.07;filter:blur(1px)">$</i>
      <i style="top:86%;right:30%;font-size:14px;opacity:.06;filter:blur(1px)">&lt;/&gt;</i>
    </div>
    <div class="hero-inner">
      <p class="pill" data-hero><span class="pill-dot"></span>Free & open source · macOS & Windows</p>
      <h1 data-hero>
        Your computer forgets what you copy. <em>Cleft doesn't.</em>
      </h1>
      <p class="hero-sub" data-hero>
        Every copy overwrites the last one — the address, the code, the color you needed again ten
        minutes later. Cleft keeps them all. Press <kbd>⌘</kbd><kbd>⇧</kbd><kbd>V</kbd> —
        <kbd>Ctrl</kbd><kbd>⇧</kbd><kbd>V</kbd> on Windows — and
        <strong>everything you've ever copied is right there</strong> — searchable, organized, and
        stored only on your machine.
      </p>
      <div class="hero-ctas" data-hero>
        <a class="btn btn-primary" href={DOWNLOAD_URL} rel="noopener">Download free</a>
        <a class="btn btn-ghost" href={REPO_URL} rel="noopener">Read the source</a>
      </div>
      <p class="hero-fineprint" data-hero>
        <b>macOS & Windows.</b> MIT licensed · No account · No telemetry
      </p>
    </div>
    <div class="demo-stage" data-hero>
      <div class="echoes" aria-hidden="true"><i></i><i></i><i></i></div>
      <span class="float-chip" style="top:-8px;left:-170px" aria-hidden="true"><span class="fc-dot" style="background:#ff8a4c"></span>#FF6B35</span>
      <span class="float-chip" style="top:110px;right:-200px" aria-hidden="true"><span class="fc-dot" style="background:#46b29d"></span>git rebase -i</span>
      <span class="float-chip" style="bottom:140px;left:-215px" aria-hidden="true"><span class="fc-dot" style="background:#b06cff"></span>{'{"ok":true}'}</span>
      <div class="demo-tilt">
        <div class="demo-zoom">
          <PaletteDemo client:load />
        </div>
      </div>
    </div>
  </header>

  <div class="marquee" aria-hidden="true">
    <div class="marquee-track">
      <span><span class="mq-badge" style="color:#ff8a4c;background:rgba(255,138,76,.12)">COLOR</span>#FF6B35</span>
      <span><span class="mq-badge" style="color:#ffa02b;background:rgba(255,160,43,.12)">SQL</span>SELECT * FROM orders</span>
      <span><span class="mq-badge" style="color:#b06cff;background:rgba(176,108,255,.12)">JSON</span>{'{"retries": 3}'}</span>
      <span><span class="mq-badge" style="color:#7c9cff;background:rgba(124,156,255,.12)">URL</span>stripe.com/docs</span>
      <span><span class="mq-badge" style="color:#46b29d;background:rgba(70,178,157,.12)">CODE</span>docker compose up -d</span>
      <span><span class="mq-badge" style="color:#c0426b;background:rgba(192,66,107,.12)">EMAIL</span>ana@acme.com</span>
      <span><span class="mq-badge" style="color:#9ca0a8;background:rgba(156,160,168,.12)">PATH</span>~/dev/cleft</span>
      <span><span class="mq-badge" style="color:#ff8a4c;background:rgba(255,138,76,.12)">COLOR</span>#FF6B35</span>
      <span><span class="mq-badge" style="color:#ffa02b;background:rgba(255,160,43,.12)">SQL</span>SELECT * FROM orders</span>
      <span><span class="mq-badge" style="color:#b06cff;background:rgba(176,108,255,.12)">JSON</span>{'{"retries": 3}'}</span>
      <span><span class="mq-badge" style="color:#7c9cff;background:rgba(124,156,255,.12)">URL</span>stripe.com/docs</span>
      <span><span class="mq-badge" style="color:#46b29d;background:rgba(70,178,157,.12)">CODE</span>docker compose up -d</span>
      <span><span class="mq-badge" style="color:#c0426b;background:rgba(192,66,107,.12)">EMAIL</span>ana@acme.com</span>
      <span><span class="mq-badge" style="color:#9ca0a8;background:rgba(156,160,168,.12)">PATH</span>~/dev/cleft</span>
    </div>
  </div>

  <section class="section" aria-labelledby="pain-title">
    <div class="wrap">
      <div class="section-head" data-reveal>
        <span class="section-eyebrow">The one-slot problem</span>
        <h2 id="pain-title">You've already lost things today.</h2>
        <p>
          The system clipboard has held exactly one item since 1984. Every copy quietly destroys the
          previous one — you only notice when it's the one you needed.
        </p>
      </div>
      <div class="pain-grid">
        <div class="pain-card" data-reveal>
          <span class="mono"><s>the address you typed out</s> → 284916</span>
          <p><b>The 2FA code</b> that just overwrote the address you spent a minute writing.</p>
        </div>
        <div class="pain-card" data-reveal>
          <span class="mono">#4F7D… <s>#4F7Dsomething?</s></span>
          <p><b>Tuesday's hex color.</b> You had it. It was perfect. It's gone.</p>
        </div>
        <div class="pain-card" data-reveal>
          <span class="mono">docker compose up -d --build ×9</span>
          <p><b>The same command,</b> re-found and re-copied for the ninth time today.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="features" aria-labelledby="features-title">
    <div class="wrap">
      <div class="section-head" data-reveal>
        <span class="section-eyebrow">⌘⇧V</span>
        <h2 id="features-title">One shortcut. Your whole copy history.</h2>
        <p>
          Cleft is a floating palette, not another window to manage. It shows up over whatever
          you're doing, hands you the clip, and gets out of the way.
        </p>
      </div>
      <div class="feature-grid">
        <div class="feature" data-reveal>
          <h3>Find it by typing anything</h3>
          <p>
            Full-text search across everything you've copied — filter by app, type, tag, or
            collection. No mouse required for any of it.
          </p>
          <div class="feature-demo"><span class="chip">app:figma</span><span class="chip">type:color</span><span class="chip">#brand</span></div>
        </div>
        <div class="feature" data-reveal>
          <h3>It knows what you copied</h3>
          <p>
            Colors get swatches. JSON gets a collapsible tree. SQL, Markdown, URLs, file paths —
            each clip is detected and previewed as what it is.
          </p>
          <div class="feature-demo">
            <span class="badge" style="color:#ff8a4c;background:rgba(255,138,76,.12)">COLOR</span>
            <span class="badge" style="color:#ffa02b;background:rgba(255,160,43,.12)">SQL</span>
            <span class="badge" style="color:#b06cff;background:rgba(176,108,255,.12)">JSON</span>
            <span class="badge" style="color:#46b29d;background:rgba(70,178,157,.12)">CODE</span>
          </div>
        </div>
        <div class="feature" data-reveal>
          <h3>It remembers where, too</h3>
          <p>
            Every clip keeps its source — the app, the window, the URL it came from. "That thing I
            copied from the Stripe docs" is a real search.
          </p>
          <div class="feature-demo"><span class="chip">Safari · stripe.com/docs</span></div>
        </div>
        <div class="feature" data-reveal>
          <h3>Rules that file it for you</h3>
          <p>
            IF a clip comes from Figma, THEN put it in Brand Colors. Automation runs at capture
            time, before you've even opened the palette.
          </p>
          <div class="feature-demo"><span class="chip chip-if">IF app == "Figma"</span><span class="chip chip-then">THEN → Brand Colors</span></div>
        </div>
        <div class="feature" data-reveal>
          <h3>Secrets never get saved</h3>
          <p>
            Password-manager output, API keys, one-time codes, card numbers — detected and refused
            at capture. Not hidden. Never written to disk at all.
          </p>
          <div class="feature-demo"><span class="chip chip-blocked">eyJhbGciOiJIUzI1NiIs…</span><span class="chip">not stored</span></div>
        </div>
        <div class="feature" data-reveal>
          <h3>Work and life, separated</h3>
          <p>
            Workspaces keep client work, personal projects, and everything else in their own
            histories. Pin what matters; it never ages out.
          </p>
          <div class="feature-demo"><span class="chip">● Personal</span><span class="chip">Work</span><span class="chip">★ pinned</span></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="privacy" aria-labelledby="privacy-title">
    <div class="wrap privacy">
      <div class="section-head" style="margin-bottom:0" data-reveal>
        <span class="section-eyebrow">Privacy</span>
        <h2 id="privacy-title">A clipboard manager sees everything you copy. That's why this one tells no one.</h2>
        <p>
          Most clipboard tools ask you to trust a privacy policy. Cleft asks you to read the code —
          audit the capture pipeline line by line before you let it watch anything.
        </p>
      </div>
      <ul class="privacy-list">
        <li data-reveal>
          <span class="privacy-check">✓</span>
          <span><b>100% local.</b> Your history is a SQLite file in your own app-data folder. Nothing is uploaded, ever.</span>
        </li>
        <li data-reveal>
          <span class="privacy-check">✓</span>
          <span><b>Zero network calls at capture.</b> Copying never triggers a request — no favicon fetches, no analytics, no telemetry.</span>
        </li>
        <li data-reveal>
          <span class="privacy-check">✓</span>
          <span><b>No account. No sign-up.</b> Download, press the shortcut, done.</span>
        </li>
        <li data-reveal>
          <span class="privacy-check">✓</span>
          <span><b>Open source, MIT.</b> The capture pipeline, the secret detection, all of it — <a href={REPO_URL} rel="noopener">public on GitHub</a>.</span>
        </li>
      </ul>
    </div>
  </section>

  <section class="cta-final">
    <div class="wrap">
      <h2 data-reveal>The next thing you copy is worth keeping.</h2>
      <p data-reveal>Thirty seconds from download to your first rescued clip. Free, open source, and it never leaves your computer.</p>
      <div class="hero-ctas" data-reveal>
        <a class="btn btn-primary" href={DOWNLOAD_URL} rel="noopener">Download Cleft free</a>
        <a class="btn btn-ghost" href={REPO_URL} rel="noopener">Star on GitHub</a>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="wrap footer-inner">
      <span>© {new Date().getFullYear()} Cleft · MIT License</span>
      <span>
        <a href={REPO_URL} rel="noopener">GitHub</a> ·
        <a href={`${REPO_URL}/issues`} rel="noopener">Report an issue</a> ·
        <a href={`${REPO_URL}/blob/main/CONTRIBUTING.md`} rel="noopener">Contribute</a>
      </span>
    </div>
  </footer>
</Layout>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    gsap.registerPlugin(ScrollTrigger);

    // Scroll progress hairline in the ember gradient.
    gsap.to('.scroll-progress', {
      scaleX: 1,
      ease: 'none',
      scrollTrigger: { start: 0, end: 'max', scrub: 0.3 },
    });

    // Hero entrance: copy staggers in, the demo rises from depth.
    gsap.from('[data-hero]', {
      opacity: 0,
      y: 26,
      duration: 0.8,
      stagger: 0.09,
      ease: 'power3.out',
    });

    // The zoom: the demo starts tilted back in 3D and flattens/scales up
    // as it scrolls through the viewport, Linear-style. Scrubbed, not
    // pinned, so it stays smooth on mobile. (Outer wrapper handles the
    // entrance opacity; this owns rotateX/scale so they never fight.)
    gsap.fromTo(
      '.demo-zoom',
      { rotateX: 14, scale: 0.9, transformOrigin: '50% 0%' },
      {
        rotateX: 0,
        scale: 1.04,
        ease: 'none',
        scrollTrigger: { trigger: '.demo-stage', start: 'top 85%', end: 'top 12%', scrub: 0.8 },
      }
    );

    // Hero copy drifts up and dims as the demo takes the stage.
    gsap.to('.hero-inner', {
      yPercent: -10,
      opacity: 0.3,
      ease: 'none',
      scrollTrigger: { trigger: '.demo-stage', start: 'top 70%', end: 'top 15%', scrub: true },
    });

    // Floating clip fragments: slow parallax at three different speeds.
    gsap.utils.toArray<HTMLElement>('.float-chip').forEach((chip, i) => {
      gsap.to(chip, {
        yPercent: -(26 + i * 16),
        ease: 'none',
        scrollTrigger: { trigger: '.demo-stage', start: 'top bottom', end: 'bottom top', scrub: 0.6 },
      });
    });

    // Section headings sharpen out of a blur; cards rise with a stagger.
    for (const el of document.querySelectorAll('.section-head[data-reveal]')) {
      gsap.fromTo(
        el,
        { opacity: 0, y: 30, filter: 'blur(8px)' },
        {
          opacity: 1,
          y: 0,
          filter: 'blur(0px)',
          duration: 0.8,
          ease: 'power2.out',
          scrollTrigger: { trigger: el, start: 'top 85%', once: true },
        }
      );
    }

    for (const grid of document.querySelectorAll('.pain-grid, .feature-grid, .privacy-list')) {
      const items = grid.querySelectorAll('[data-reveal]');
      gsap.fromTo(
        items,
        { opacity: 0, y: 26 },
        {
          opacity: 1,
          y: 0,
          duration: 0.6,
          stagger: 0.08,
          ease: 'power2.out',
          scrollTrigger: { trigger: grid, start: 'top 84%', once: true },
        }
      );
    }

    // Final CTA scales in with its glow.
    for (const el of document.querySelectorAll('.cta-final [data-reveal]')) {
      gsap.fromTo(
        el,
        { opacity: 0, y: 22, scale: 0.96 },
        {
          opacity: 1,
          y: 0,
          scale: 1,
          duration: 0.7,
          stagger: 0.08,
          ease: 'power2.out',
          scrollTrigger: { trigger: '.cta-final', start: 'top 78%', once: true },
        }
      );
    }

    // Layout settles after the React island and fonts land.
    window.addEventListener('load', () => ScrollTrigger.refresh());
  } else {
    for (const el of document.querySelectorAll<HTMLElement>('[data-reveal]')) el.style.opacity = '1';
  }

  // Cursor spotlight on feature cards (pointer devices only; CSS gates the
  // visual behind hover support).
  for (const card of document.querySelectorAll<HTMLElement>('.feature')) {
    card.addEventListener('pointermove', (e) => {
      const r = card.getBoundingClientRect();
      card.style.setProperty('--mx', `${e.clientX - r.left}px`);
      card.style.setProperty('--my', `${e.clientY - r.top}px`);
    });
  }
</script>

<style is:global>
  /* Palette demo (PaletteDemo.tsx) */
  .pd {
    display: flex;
    flex-direction: column;
    gap: 14px;
    min-width: 0;
  }

  .pd-slot {
    display: flex;
    align-items: baseline;
    gap: 10px;
    padding: 10px 14px;
    border: 1px dashed var(--line-2);
    border-radius: 11px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--faint);
  }

  .pd-slot-label {
    flex-shrink: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 10.5px;
  }

  .pd-slot-value {
    color: var(--muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
    flex: 1;
  }

  .pd-slot-note {
    flex-shrink: 0;
    color: var(--sun);
  }

  .pd-window {
    position: relative;
    border: 1px solid var(--line-2);
    border-radius: 18px;
    background: rgba(16, 17, 20, 0.82);
    backdrop-filter: blur(10px);
    box-shadow:
      0 32px 80px rgba(0, 0, 0, 0.55),
      0 0 60px rgba(255, 107, 53, 0.07),
      inset 0 1px 0 rgba(255, 255, 255, 0.07);
    overflow: hidden;
  }

  .pd-search {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 16px;
    border-bottom: 1px solid var(--line);
    color: var(--faint);
    font-size: 13.5px;
  }

  .pd-search span:nth-child(2) {
    flex: 1;
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
  }

  .pd-kbd {
    font-size: 11px;
    font-weight: 600;
    color: var(--muted);
    border: 1px solid var(--line-2);
    border-radius: 6px;
    padding: 2px 7px;
  }

  .pd-list {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 8px;
    min-height: 232px;
  }

  .pd-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 10px;
    border-radius: 9px;
  }

  .pd-row:first-child {
    background: rgba(255, 107, 53, 0.09);
    box-shadow: inset 0 0 0 1px rgba(255, 107, 53, 0.28);
  }

  .pd-icon {
    flex-shrink: 0;
    width: 26px;
    height: 26px;
    border-radius: 7px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 700;
    color: #fff;
  }

  .pd-preview {
    flex: 1;
    min-width: 0;
    font-family: var(--font-mono);
    font-size: 12.5px;
    color: var(--paper);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .pd-badge {
    flex-shrink: 0;
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: 0.05em;
    padding: 2px 7px;
    border: 1px solid;
    border-radius: 5px;
  }

  .pd-footer {
    display: flex;
    justify-content: space-between;
    padding: 10px 16px;
    border-top: 1px solid var(--line);
    font-size: 11.5px;
    color: var(--faint);
  }

  .pd-dot {
    color: #46b29d;
    font-size: 8px;
    vertical-align: 1px;
  }
</style>
