{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cleft",
  "version": "0.1.0",
  "identifier": "com.andydev404.cleft",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 880,
        "height": 560,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "visible": false,
        "center": true,
        "label": "main"
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQwMkQ4MjZGRTExRUQ4QjIKUldTeTJCN2hiNEl0MEt3cUpmM1BhcjFDVEw1N0tzWS91YmJnVTRCb0xjSXY2VVJKbkZ2VnRaa3UK",
      "endpoints": [
        "https://github.com/andydev404/cleft/releases/latest/download/latest.json"
      ]
    }
  }
}
